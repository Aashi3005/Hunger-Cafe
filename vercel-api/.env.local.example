# ─────────────────────────────────────────────────────────────────────────────
# AI Provider Keys — add whichever ones you have.
# The backend auto-selects the best available provider in this priority order:
#   1. Google Gemini  (fastest, free tier generous)
#   2. OpenAI GPT-4o Mini
#   3. Anthropic Claude 3.5 Haiku
#   4. Mistral Small
# You only need ONE key to get started.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini — https://makersuite.google.com/app/apikey
# Unlocks: gemini-2.0-flash, gemini-1.5-flash
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# OpenAI — https://platform.openai.com/api-keys
# Unlocks: gpt-4o-mini, gpt-4o  +  DALL-E 3 image generation
OPENAI_API_KEY=your_openai_key_here

# Anthropic — https://console.anthropic.com/settings/keys
# Unlocks: claude-3-5-haiku, claude-3-5-sonnet
ANTHROPIC_API_KEY=your_anthropic_key_here

# Mistral — https://console.mistral.ai/api-keys
# Unlocks: mistral-small (cheapest option at $0.0002/1k tokens)
MISTRAL_API_KEY=your_mistral_key_here

# ── Image providers ───────────────────────────────────────────────────────────
# Unsplash — https://unsplash.com/developers (500 req/hr free tier)
# Without this, fetchDishImage falls back to Pollinations (always free, AI-generated)
UNSPLASH_ACCESS_KEY=your_unsplash_key_here
